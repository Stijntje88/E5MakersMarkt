<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.OrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="24">
        <StackPanel Spacing="14" MaxWidth="500">
            <TextBlock Text="Makers Markt"
                       FontSize="28"
                       FontWeight="SemiBold"
                       CharacterSpacing="100"/>

            <TextBlock Text="Bestel"
                       FontSize="28"
                       FontWeight="SemiBold"
                       CharacterSpacing="100"/>

            <TextBlock x:Name="ProductNameText"
                       Text="Product: -"
                       FontSize="16"
                       FontWeight="SemiBold"/>

            <TextBlock x:Name="UsernameText"
                       Text="Ingelogd als: -"
                       FontSize="14"/>

            <TextBlock Text="Prijs"/>
            <TextBox x:Name="PriceTextBox"
                     PlaceholderText="Bijv. 19.99"/>

            <Button Content="Plaats bestelling"
                    Click="PlaceOrder_Click"
                    Height="40"
                    FontWeight="SemiBold"
                    CornerRadius="8"
                    Background="#855400"
                    Foreground="White"
                    BorderThickness="0"/>

            <TextBlock x:Name="StatusText" Foreground="#864f0c" TextWrapping="Wrap"/>

            <Button Content="Ga terug"
                    Click="GoBack_Click"
                    Height="36"
                    FontWeight="SemiBold"
                    FontSize="13"
                    CornerRadius="8"
                    Background="#855400"
                    Foreground="White"
                    HorizontalAlignment="Left"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Page>
