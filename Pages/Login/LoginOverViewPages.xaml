<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.Login.LoginOverViewPages"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages.Login"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="White">

        <Border BorderBrush="SaddleBrown"
            BorderThickness="5"
            CornerRadius="12"
            Padding="90"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel Spacing="5">

                <Image Source="/Pictures/Logo.png"
                   Width="500"
                   Height="300"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"/>

                <StackPanel Spacing="8">
                    <TextBlock Text="Username"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="SaddleBrown"/>
                    <TextBox x:Name="UsernameBox"
                         PlaceholderText="Enter your Username"
                         Background="LightGray"
                         Foreground="Black"
                         BorderBrush="#374151"
                         BorderThickness="2"
                         CornerRadius="8"
                         Height="44"
                         Padding="12,8"/>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Password"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="SaddleBrown"/>
                    <PasswordBox x:Name="PasswordBox"
                             PlaceholderText="Enter your password"
                             Background="LightGray"
                             BorderBrush="#374151"
                             BorderThickness="2"
                             CornerRadius="8"
                             Height="44"
                             Padding="12,8"/>
                </StackPanel>

                <TextBlock x:Name="ErrorMessage"
                       TextAlignment="Center"
                       Foreground="#EF4444"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
                <StackPanel Spacing="10">

                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <Button Content="Login"
                            Click="Login_Click"
                            Width="140"
                            Height="36"
                            FontWeight="SemiBold"
                            FontSize="13"
                            CornerRadius="8"
                            Background="Black"
                            Foreground="White"
                            BorderThickness="0"/>

                        <Button Content="Register"
                            Click="Register_Click"
                            Width="140"
                            Height="36"
                            FontWeight="SemiBold"
                            FontSize="13"
                            CornerRadius="8"
                            Background="Black"
                            Foreground="White"
                            BorderThickness="0"/>
                        </StackPanel>

                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <Button Content="DEV Login [Beheer]"
                            Click="DevLoginAdmin_Click"
                            Width="140"
                            Height="36"
                            FontWeight="SemiBold"
                            FontSize="13"
                            CornerRadius="8"
                            Background="Black"
                            Foreground="White"
                            BorderThickness="0"/>

                        <Button Content="DEV Login [Player]"
                            Click="DevLoginPlayer_Click"
                            Width="140"
                            Height="36"
                            FontWeight="SemiBold"
                            FontSize="13"
                            CornerRadius="8"
                            Background="Black"
                            Foreground="White"
                            BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
