<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.DetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages"
    xmlns:LocalData="using:E5MakersMarkt.Data.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>


        </Grid.RowDefinitions>
        <ListView x:Name="ProductListView" Grid.Row="0" 
                                    >
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="LocalData:UserProduct">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{x:Bind Product.Name}" Width="150"/>
                        <TextBlock Text="{x:Bind User.Username}" Width="150"/>
                        <TextBlock Text="{x:Bind Product.Type}" Width="100"/>
                        
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Content="Home" Grid.Row="1"
    Click="Home_Click"
    Width="150"
    Height="40"
    FontWeight="SemiBold"
    CornerRadius="10"
    Background="#C08A5B"
    Foreground="White"
    BorderThickness="0"/>

   
            <Button Content="Order"
                Click="Order_Click"
                Width="150"
                Height="40"
                FontWeight="SemiBold"
                CornerRadius="10"
                Background="#C08A5B"
                Foreground="White"
                BorderThickness="0"/>
        

    </Grid>
</Page>
