<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.DetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages"
    xmlns:LocalData="using:E5MakersMarkt.Data.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="10">

        <!-- Duidelijke layout -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Product -->
            <RowDefinition Height="Auto"/>
            <!-- Home -->
            <RowDefinition Height="Auto"/>
            <!-- Order -->
            <RowDefinition Height="Auto"/>
            <!-- Form -->
            <RowDefinition Height="*"/>
            <!-- Comments -->
        </Grid.RowDefinitions>

        <!-- PRODUCT INFO -->
        <ListView x:Name="ProductListView" Grid.Row="0">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="LocalData:UserProduct">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{x:Bind Product.Name}" Width="150"/>
                        <TextBlock Text="{x:Bind User.Username}" Width="150"/>
                        <TextBlock Text="{x:Bind Product.Type}" Width="100"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- BUTTONS -->
        <Button Content="Home"
                Grid.Row="1"
                Click="Home_Click"
                Width="150"
                Height="40"
                Margin="0,10,0,0"
                CornerRadius="10"
                Background="#C08A5B"
                Foreground="White"/>

        <Button Content="Order"
                Grid.Row="2"
                Click="Order_Click"
                Width="150"
                Height="40"
                Margin="0,10,0,0"
                CornerRadius="10"
                Background="#C08A5B"
                Foreground="White"/>

        <!-- COMMENT FORM -->
        <StackPanel Grid.Row="3" Spacing="10" Margin="0,20,0,20">

            <TextBlock Text="Plaats een reactie"
                       FontSize="18"
                       FontWeight="Bold"/>

            <TextBox x:Name="CommentTitle"
                     Header="Titel"
                     PlaceholderText="Voer een titel in"/>

            <TextBox x:Name="CommentDescription"
                     Header="Beschrijving"
                     PlaceholderText="Schrijf je reactie"
                     AcceptsReturn="True"
                     Height="80"/>

            <TextBox x:Name="CommentRating"
                     Header="Rating (1-5)"
                     PlaceholderText="Bijv. 5"/>

            <Button Content="Plaats comment"
                    Click="AddComment_Click"/>
        </StackPanel>

        <!-- COMMENTS LIST -->
        <ListView x:Name="commentlistView" Grid.Row="4">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="LocalData:Comment">
                    <StackPanel Spacing="5" Margin="0,0,0,15">

                        
                        <TextBlock Text="{x:Bind CommentTitle}" FontWeight="Bold"/>

                        <TextBlock Text="{x:Bind User.Username}" FontStyle="Italic"/>

                        <TextBlock Text="{x:Bind Description}" TextWrapping="WrapWholeWords"/>

                        <TextBlock Text="{x:Bind Rating}"/>

                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>