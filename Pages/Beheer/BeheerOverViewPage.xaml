<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.Beheer.BeheerOverViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages.Beheer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#E7E1D4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Background="#8B5E3C">
            <StackPanel Margin="20">
                <StackPanel Margin="0,0,0,40">
                    <TextBlock Text="🛠️ MakersMarkt"
                     FontSize="24"
                     FontWeight="Bold"
                     Foreground="White"/>

                    <TextBlock Text="Admin Panel"
                    FontSize="12"
                    Foreground="White"
                    Margin="0,5,0,0"/>
                </StackPanel>

                <Button Content="📊 Dashboard"
                    Margin="0,5"
                    Padding="15,12"
                    Background="#C08A5B"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="BeheerOverviewButton_Click">
                </Button>

                <Button Content="👥 Gebruikers"
                    Margin="0,5"
                    Padding="15,12"
                    Background="#C08A5B"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="UserButton_Click">
                </Button>
                <Button Content="✔️ Veriferen"
                    Margin="0,5"
                    Padding="15,12"
                    Background="#C08A5B"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="Verified_Click">
                </Button>
                <Button x:Name="Logout"
                    Content="🚪 Uitloggen"
                    Margin="0,60,0,0"
                    Padding="15,12"
                    Background="#EF4444"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="Logout_Click">
                </Button>
            </StackPanel>
        </Grid>


        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Grid Background="#8B5E3C" Padding="30,0">
                <TextBlock 
                    Text="Admin Dashboard"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="White"
                    VerticalAlignment="Center"/>
            </Grid>


            <ScrollViewer Grid.Row="1" Margin="30,20,30,30">
                <StackPanel Spacing="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Border Background="White"
                                Grid.Column="0"
                            CornerRadius="12"
                            Padding="25"
                            Margin="0,0,10,0"
                            BorderBrush="#C08A5B"
                            BorderThickness="2">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                                    <TextBlock Text="👥" FontSize="24"/>
                                    <TextBlock Text="Totalen Gebruikers"
                                    FontSize="16"
                                    Foreground="#3E2A1F"/>
                                </StackPanel>

                                <TextBlock x:Name="TotalUsersText"
                                    Text="0"
                                    FontSize="48"
                                    FontWeight="Bold"
                                    Foreground="#3E2A1F"/>
                                <TextBlock Text="Geregisterden Accounts"
                                    Foreground="#3E2A1F"
                                    FontSize="12"
                                    Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White"
                             CornerRadius="12"
                             Padding="25"
                             Margin="0,0,10,0"
                             BorderBrush="#C08A5B"
                             BorderThickness="2"
                                Grid.Column="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
                                    <TextBlock Text="✔️" FontSize="24"/>
                                    <TextBlock Text="Totalen Geverifieerde Users"
                                     FontSize="16"
                                     Foreground="#3E2A1F"/>
                                </StackPanel>

                                <TextBlock x:Name="TotalVerfiedUser"
                                     Text="0"
                                     FontSize="48"
                                     FontWeight="Bold"
                                     Foreground="#3E2A1F"/>
                                <TextBlock Text="Geverifieerde Accounts"
                                     Foreground="#3E2A1F"
                                     FontSize="12"
                                     Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
