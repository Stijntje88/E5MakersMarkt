<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.Beheer.BeheerOverViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages.Beheer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    
    <Grid Background="#FFDEA6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Background="#855400">
            <StackPanel Margin="0,0,0,40">
                <TextBlock Text="🛠️ MakersMarkt"
                 FontSize="24"
                 FontWeight="Bold"
                 Foreground="White"/>

                <TextBlock Text="Admin Panel"
                FontSize="12"
                Foreground="White"
                Margin="0,5,0,0"/>
            </StackPanel>

            <Button Content="📊 Dashboard"
                Margin="0,5"
                Padding="15,12"
                Background="#C97F00"
                Foreground="White"
                CornerRadius="8"
                FontWeight="SemiBold"
                BorderThickness="0"
                Click="BeheerOverviewButton_Click"/>
        </Grid>
    </Grid>
</Page>
