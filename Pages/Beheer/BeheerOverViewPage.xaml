<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.Beheer.BeheerOverViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages.Beheer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#E7E1D4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Background="#8B5E3C">
            <StackPanel Margin="20">
                <StackPanel Margin="0,0,0,40">
                    <TextBlock Text="🛠️ MakersMarkt"
                     FontSize="24"
                     FontWeight="Bold"
                     Foreground="White"/>

                    <TextBlock Text="Admin Panel"
                    FontSize="12"
                    Foreground="White"
                    Margin="0,5,0,0"/>
                </StackPanel>

                <Button Content="📊 Dashboard"
                    Margin="0,5"
                    Padding="15,12"
                    Background="#C08A5B"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="BeheerOverviewButton_Click">
                </Button>

                <Button Content="👥 Gebruikers"
                    Margin="0,5"
                    Padding="15,12"
                    Background="#C08A5B"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="UserButton_Click">
                </Button>
                <Button x:Name="Logout"
                    Content="🚪 Uitloggen"
                    Margin="0,60,0,0"
                    Padding="15,12"
                    Background="#EF4444"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="Logout_Click">
                </Button>
            </StackPanel>
        </Grid>


        <Grid Grid.Column="1">
            <StackPanel Spacing="20"
                Padding="20"
                Background="#FDF8F3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <Border Background="#FFF"
                    CornerRadius="12"
                    Padding="25"
                    MaxWidth="320">

                    <StackPanel Spacing="15"
                        HorizontalAlignment="Center">

                        <TextBlock Text="⚙ Maintenance"
                           FontSize="18"
                           Foreground="#5C4033"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>


                        <ProgressRing IsActive="True"
                          Width="40"
                          Height="40"
                          Foreground="#5C4033"/>

                        <TextBlock x:Name="NameTextBox"
                           Text="Het BeheerDashboard is momenteel in de maak..."
                           TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="#3E2A1F"
                           Opacity="0.85"
                           TextAlignment="Center"/>

                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </Grid>
</Page>
