<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.Beheer.BeheerUserOverViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages.Beheer"
    xmlns:localData="using:E5MakersMarkt.Data.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#E7E1D4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Background="#8B5E3C">
            <StackPanel Margin="20">
                <StackPanel Margin="0,0,0,40">
                    <TextBlock Text="🛠️ MakersMarkt"
                     FontSize="24"
                     FontWeight="Bold"
                     Foreground="white"/>

                    <TextBlock Text="Admin Panel"
                    FontSize="12"
                    Foreground="White"
                    Margin="10,5,0,0"/>
                </StackPanel>

                <Button Content="📊 Dashboard"
                    Margin="0,5"
                    Padding="15,12"
                    Background="#C08A5B"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="BeheerOverviewButton_Click">
                </Button>

                <Button Content="👥 Gebruikers"
                    Margin="0,5"
                    Padding="15,12"
                    Background="#C08A5B"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="UserButton_Click">
                </Button>
                <Button x:Name="Logout"
                    Content="🚪 Uitloggen"
                    Margin="0,60,0,0"
                    Padding="15,12"
                    Background="#EF4444"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="Logout_Click">
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">


            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/> 
            </Grid.RowDefinitions>

            <Grid Background="#8B5E3C" Padding="30,0">
                <TextBlock Text="👥 Gebruikers Management"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </Grid>

            
                <Grid Grid.Row="1" Margin="30,20,30,10">
                <TextBox x:Name="userSearchTextBox"
                         PlaceholderText="🔍 Zoek Gebruiker bij naam."
                         TextChanged="userSearchTextBox_TextChanged"
                         Background="White"
                         Foreground="#5C4033"
                         PlaceholderForeground="#A68A75"
                         BorderBrush="#CBB89D"
                         BorderThickness="2"
                         CornerRadius="8"
                         Height="44"
                         Padding="15,10"/>
            </Grid>

            <ListView Grid.Row="2"
                Margin="30,0,30,30"
                x:Name="BeheerUserList"
                Background="Transparent"
                SelectionMode="None">

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="localData:User">
                        <Border Background="White"
                                CornerRadius="12"
                                BorderThickness="2"
                                BorderBrush="#D6C3A3"
                                Padding="20"
                                Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="#C08A5B"
                                        CornerRadius="8"
                                        Width="50"
                                        Height="50">
                                    <TextBlock Text="{Binding Id}"
                                        Foreground="White"
                                        FontSize="20"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                    <TextBlock Text="{Binding Username}"
                                               Foreground="#3E2A1F"
                                               FontSize="18"/>


                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="🎭" FontSize="14"/>
                                        <TextBlock Text="Rol: " FontSize="14" Foreground="#8B5E3C"/>
                                        <TextBlock Text="{Binding Role}"
                                                       Foreground="#8B5E3C"
                                                       FontSize="14"    
                                                       FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="10">

                                    <Button Content="🛠️ Bewerken"
                                            Background="DarkBlue"
                                            Foreground="White"
                                            Padding="12,8"
                                            CornerRadius="6"
                                            FontWeight="SemiBold"
                                            Click="Edit_Click">
                                    </Button>

                                    <Button Content="🗑️ Verwijderen"
                                            Background="#EF4444"
                                            Foreground="White"
                                            Padding="12,8"
                                            CornerRadius="6"
                                            FontWeight="SemiBold"
                                            Click="DeleteUserButton_Click">
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
