<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.Beheer.BeheerUserOverViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages.Beheer"
    xmlns:localData="using:E5MakersMarkt.Data.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#FFDEA6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Background="#855400">
            <StackPanel Margin="20">
                <StackPanel Margin="0,0,0,40">
                    <TextBlock Text="🛠️ MakersMarkt"
                     FontSize="24"
                     FontWeight="Bold"
                     Foreground="White"/>

                    <TextBlock Text="Admin Panel"
                    FontSize="12"
                    Foreground="White"
                    Margin="0,5,0,0"/>
                </StackPanel>

                <Button Content="📊 Dashboard"
                    Margin="0,5"
                    Padding="15,12"
                    Background="#C97F00"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="BeheerOverviewButton_Click">
                </Button>

                <Button Content="👥 Gebruikers"
                    Margin="0,5"
                    Padding="15,12"
                    Background="#C97F00"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="UserButton_Click">
                </Button>
                <Button x:Name="Logout"
                    Content="🚪 Uitloggen"
                    Margin="0,60,0,0"
                    Padding="15,12"
                    Background="#EF4444"
                    Foreground="White"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Click="Logout_Click">
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">


            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="#855400" Padding="30,0">
                <TextBlock Text="👥 User Management"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </Grid>

            
                <Grid Grid.Row="1" Margin="30,20,30,10">
                <TextBox x:Name="userSearchTextBox"
                         PlaceholderText="🔍 Search users by name or email..."
                         TextChanged="userSearchTextBox_TextChanged"
                         Background="#855400"
                         Foreground="White"
                         PlaceholderForeground="#9CA3AF"
                         BorderBrush="#755400"
                         BorderThickness="2"
                         CornerRadius="8"
                         Height="44"
                         Padding="15,10"/>
            </Grid>

            <ListView Grid.Row="2"
                Margin="30,0,30,30"
                x:Name="BeheerUserList"
                Background="Transparent"
                SelectionMode="None">

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="localData:User">
                        <Border Background="#955400"
                                CornerRadius="12"
                                BorderThickness="2"
                                BorderBrush="#755400"
                                Padding="20"
                                Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="#374151"
                                        CornerRadius="8"
                                        Width="50"
                                        Height="50">
                                    <TextBlock Text="{Binding Id}"
                                        Foreground="#FBBF24"
                                        FontSize="20"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                                    <TextBlock Text="{Binding Username}"
                                               Foreground="White"
                                               FontSize="18"/>
                               
                                    
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="🎭" FontSize="14"/>
                                        <TextBlock Text="Role: " FontSize="14" Foreground="#60A5FA"/>
                                        <TextBlock Text="{Binding Role}"
                                                       Foreground="#60A5FA"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"/>
                                </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
