<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E5MakersMarkt.Pages.HomePages"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E5MakersMarkt.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Search & Buttons -->
            <RowDefinition Height="*"/>
            <!-- ListView -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Makers Markt"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#864f0c"/>
            
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="Item toevoegen"
                        Click="AddItem_Click"
                        Width="140" Height="40"
                        FontWeight="SemiBold"
                        CornerRadius="8"
                        Background="#855400"
                        Foreground="White"/>
                
                <Button Content="Log uit"
                        Click="LogOut_Click"
                        Width="100" Height="40"
                        FontWeight="SemiBold"
                        CornerRadius="8"
                        Background="#855400"
                        Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- Search Bar -->
        <Border Grid.Row="1"
                CornerRadius="8"
                BorderBrush="#864f0c"
                BorderThickness="1"
                Background="#F9FAFB"
                Padding="15,5"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <FontIcon Grid.Column="0"
                          Glyph="&#xE721;"
                          FontSize="16"
                          Foreground="#864f0c"
                          Margin="0,0,10,0"
                          VerticalAlignment="Center"/>

                <TextBox Grid.Column="1"
                         x:Name="SearchBox"
                         PlaceholderText="Zoek naar producten..."
                         TextChanged="SearchBox_TextChanged"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="15"
                         VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ListView -->
        <ListView Grid.Row="2"
                  x:Name="ItemList"
                  IsItemClickEnabled="True"
                  ItemClick="ProductList_ItemClick"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15"
                            Margin="0,5,0,10"
                            CornerRadius="8"
                            Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding Name}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#1F2937"/>
                            
                            <TextBlock Text="{Binding Description}"
                                       FontSize="14"
                                       Foreground="#4B5563"
                                       TextWrapping="WrapWholeWords"
                                       Margin="0,0,0,10"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="Type:" Foreground="Gray" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Type}" Foreground="#374151"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="Materiaal:" Foreground="Gray" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Material}" Foreground="#374151"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="Productietijd:" Foreground="Gray" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ProductionTime}" Foreground="#374151"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>

</Page>